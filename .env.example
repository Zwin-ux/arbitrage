# Public recorder settings only. Do not put private keys or API secrets in this file.
PMR_GAMMA_API_URL=https://gamma-api.polymarket.com
PMR_CLOB_API_URL=https://clob.polymarket.com
PMR_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
PMR_DUCKDB_PATH=data/market_data.duckdb
PMR_DISCOVERY_LIMIT=500
PMR_DISCOVERY_MAX_PAGES=
PMR_DISCOVERY_ORDER=volume_24hr
PMR_DISCOVERY_ASCENDING=false
PMR_BOOTSTRAP_BATCH_SIZE=50
PMR_STALE_AFTER_SECONDS=30
PMR_STALE_CHECK_INTERVAL_SECONDS=10
PMR_REDISCOVERY_INTERVAL_SECONDS=300
PMR_RECONNECT_INITIAL_SECONDS=1
PMR_RECONNECT_MAX_SECONDS=30
PMR_WS_PING_INTERVAL_SECONDS=20
PMR_WS_PING_TIMEOUT_SECONDS=20
PMR_AUTO_SUBSCRIBE_NEW_MARKETS=true
PMR_UNSUBSCRIBE_RESOLVED_MARKETS=true
PMR_LOG_LEVEL=INFO
