{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Superior",
  "version": "0.1.0",
  "identifier": "com.superior.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Superior",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/128x128.png"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
