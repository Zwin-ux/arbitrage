---
import BaseLayout from "../layouts/BaseLayout.astro";

const sourceUrl = "https://github.com/Zwin-ux/arbitrage";
const docsRoot = "https://github.com/Zwin-ux/arbitrage/tree/main/docs";
---

<BaseLayout title="Docs | Superior" description="Repo docs, build commands, and quality gates for Superior's Windows Kalshi starter bot shell.">
  <section class="machine-page">
    <header class="machine-page__header">
      <div class="machine-page__title">
        <span class="machine-page__label">Docs</span>
        <strong>Repo docs / local build</strong>
      </div>
      <div class="machine-page__status">SOURCE / BUILD / SHADOW / AUTO</div>
    </header>

    <div class="machine-page__body machine-page__body--single">
      <div class="machine-page__column">
        <div class="machine-page__rail">
          <article class="machine-page__strip">
            <span class="machine-page__strip-label">First run</span>
            <div class="machine-page__strip-body">
              <strong>Shadow before anything auto</strong>
              <p>Clear the learn ladder and one shadow run before you arm the starter bot.</p>
            </div>
          </article>

          <article class="machine-page__strip">
            <span class="machine-page__strip-label">Build</span>
            <div class="machine-page__strip-body">
              <strong>Desktop shell and site live in this repo</strong>
              <p>Use the repo docs for local dev, packaging, and the staged live path.</p>
            </div>
          </article>

          <article class="machine-page__strip">
            <span class="machine-page__strip-label">Checks</span>
            <div class="machine-page__strip-body">
              <strong>Build, test, then ship</strong>
              <p>The public site and Windows app should pass the same local checks before release.</p>
            </div>
          </article>
        </div>

        <div class="machine-page__code-wrap">
          <span class="machine-page__code-title">Quick start</span>
          <pre class="machine-page__code"><code>npm --prefix desktop-v1 install
npm --prefix desktop-v1 run dev</code></pre>
        </div>

        <div class="machine-page__code-wrap">
          <span class="machine-page__code-title">Release build</span>
          <pre class="machine-page__code"><code>npm --prefix desktop-v1 run build
npm --prefix desktop-v1 run tauri:build</code></pre>
        </div>

        <div class="machine-page__code-wrap">
          <span class="machine-page__code-title">Quality gates</span>
          <pre class="machine-page__code"><code>npm --prefix desktop-v1 run check
npm --prefix desktop-v1 run test
npm --prefix site run build
npm --prefix site run test:browser</code></pre>
        </div>
      </div>
    </div>

    <nav class="machine-page__controls" aria-label="Docs controls">
      <a class="machine-page__control machine-page__control--primary" href={sourceUrl} target="_blank" rel="noreferrer">
        <span>Open GitHub</span>
      </a>
      <a
        class="machine-page__control machine-page__control--secondary"
        href={`${docsRoot}/first-paper-run.md`}
        target="_blank"
        rel="noreferrer"
      >
        <span>First shadow run</span>
      </a>
      <a
        class="machine-page__control machine-page__control--commit"
        href={`${docsRoot}/release-checklist.md`}
        target="_blank"
        rel="noreferrer"
      >
        <span>Release checklist</span>
      </a>
      <a class="machine-page__control machine-page__control--reset" href={docsRoot} target="_blank" rel="noreferrer">
        <span>Docs root</span>
      </a>
    </nav>
  </section>
</BaseLayout>
