---
import BaseLayout from "../layouts/BaseLayout.astro";

const sourceUrl = "https://github.com/Zwin-ux/arbitrage";
const docsRoot = "https://github.com/Zwin-ux/arbitrage/tree/main/docs";
---

<BaseLayout title="Docs | Superior" description="Repo docs, build commands, and quality gates for Superior.">
  <section class="machine-page">
    <header class="machine-page__header">
      <div class="machine-page__title">
        <span class="machine-page__label">Docs</span>
        <strong>Repo / guides / operations</strong>
      </div>
      <div class="machine-page__status">SOURCE / LOCAL / PUBLIC</div>
    </header>

    <div class="machine-page__body">
      <div class="machine-page__column">
        <div class="machine-page__stack">
          <div class="machine-page__block">
            <span>Docs root</span>
            <strong>GitHub repo docs are the source of truth.</strong>
            <p>Use the repo for trust docs, first paper run, and release procedures.</p>
          </div>
          <div class="machine-page__block">
            <span>Trust</span>
            <strong>Risk model / live limitations / privacy and secrets.</strong>
            <p>Paper-first posture stays visible before any live path is considered.</p>
          </div>
          <div class="machine-page__block">
            <span>Deploy</span>
            <strong>Railway hosts the site only.</strong>
            <p>Set the service root to <code>/site</code>. Keep runtime, data, and secrets local.</p>
          </div>
        </div>

        <div class="machine-page__list">
          <div class="machine-page__row">
            <span>Guide</span>
            <strong>First paper run</strong>
          </div>
          <div class="machine-page__row">
            <span>Release</span>
            <strong>Release checklist</strong>
          </div>
          <div class="machine-page__row">
            <span>Support</span>
            <strong>Issue templates shorten diagnosis.</strong>
          </div>
        </div>
      </div>

      <div class="machine-page__column">
        <div class="machine-page__code-wrap">
          <span class="machine-page__code-title">Quick start</span>
          <pre class="machine-page__code"><code>python -m pip install -e ".[dev]"
market-data-recorder-app
market-data-recorder record</code></pre>
        </div>

        <div class="machine-page__code-wrap">
          <span class="machine-page__code-title">Release build</span>
          <pre class="machine-page__code"><code>powershell -ExecutionPolicy Bypass -File scripts/bootstrap-iscc.ps1
powershell -ExecutionPolicy Bypass -File scripts/build-windows-release.ps1</code></pre>
        </div>

        <div class="machine-page__code-wrap">
          <span class="machine-page__code-title">Quality gates</span>
          <pre class="machine-page__code"><code>pytest -q
python -m mypy src tests
market-data-recorder-qa --headless --output .tmp/qa-report.json
npm --prefix site ci
npm --prefix site run build</code></pre>
        </div>
      </div>
    </div>

    <nav class="machine-page__controls" aria-label="Docs controls">
      <a class="machine-page__control machine-page__control--primary" href={sourceUrl} target="_blank" rel="noreferrer">
        <span>Open GitHub</span>
      </a>
      <a
        class="machine-page__control machine-page__control--secondary"
        href={`${docsRoot}/first-paper-run.md`}
        target="_blank"
        rel="noreferrer"
      >
        <span>First paper run</span>
      </a>
      <a
        class="machine-page__control machine-page__control--commit"
        href={`${docsRoot}/release-checklist.md`}
        target="_blank"
        rel="noreferrer"
      >
        <span>Release checklist</span>
      </a>
      <a class="machine-page__control machine-page__control--reset" href={docsRoot} target="_blank" rel="noreferrer">
        <span>Docs root</span>
      </a>
    </nav>
  </section>
</BaseLayout>
