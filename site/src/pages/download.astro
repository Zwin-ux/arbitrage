---
import BaseLayout from "../layouts/BaseLayout.astro";

const installerUrl = "https://github.com/Zwin-ux/arbitrage/releases/latest/download/market-data-recorder-setup.exe";
const portableUrl = "https://github.com/Zwin-ux/arbitrage/releases/latest/download/market-data-recorder-app-portable.zip";
const checksumsUrl = "https://github.com/Zwin-ux/arbitrage/releases/latest/download/SHA256SUMS.txt";
const sourceUrl = "https://github.com/Zwin-ux/arbitrage";
---

<BaseLayout
  title="Download | Superior"
  description="Download the Superior Windows build, verify the release artifact, and keep the first run inside a paper-first path."
>
  <section class="machine-page">
    <header class="machine-page__header">
      <div class="machine-page__title">
        <span class="machine-page__label">Download</span>
        <strong>Windows build / test first</strong>
      </div>
      <div class="machine-page__status">LOCAL / LIVE LOCKED</div>
    </header>

    <div class="machine-page__body">
      <div class="machine-page__column">
        <div class="machine-page__stack">
          <div class="machine-page__block">
            <span>Installer</span>
            <strong>market-data-recorder-setup.exe</strong>
            <p>Best path for first setup. Shortcuts and uninstall support included.</p>
          </div>
          <div class="machine-page__block">
            <span>Portable</span>
            <strong>market-data-recorder-app-portable.zip</strong>
            <p>Folder build. No installer. Good for demos and isolated runs.</p>
          </div>
          <div class="machine-page__block">
            <span>Verify</span>
            <strong>SHA256SUMS.txt</strong>
            <p>Compare the hash before launch if SmartScreen blocks the run.</p>
          </div>
        </div>

        <div class="machine-page__code-wrap">
          <span class="machine-page__code-title">Source path</span>
          <pre class="machine-page__code"><code>python -m pip install -e ".[dev]"
market-data-recorder-app</code></pre>
        </div>
      </div>

      <div class="machine-page__column">
        <div class="machine-page__list">
          <div class="machine-page__row">
            <span>Profile</span>
            <strong>Create a guided profile.</strong>
          </div>
          <div class="machine-page__row">
            <span>Credentials</span>
            <strong>Leave credentials blank if recorder plus practice mode is enough.</strong>
          </div>
          <div class="machine-page__row">
            <span>Copilot</span>
            <strong>OpenAI-compatible, Anthropic, Gemini, or Ollama are optional.</strong>
          </div>
          <div class="machine-page__row">
            <span>Sequence</span>
            <strong>Record first. Inspect the route. Keep live locked.</strong>
          </div>
          <div class="machine-page__row">
            <span>Secrets</span>
            <strong>Use the OS keychain. Not JSON. Not DuckDB. Not logs.</strong>
          </div>
        </div>
      </div>
    </div>

    <nav class="machine-page__controls" aria-label="Download controls">
      <a class="machine-page__control machine-page__control--primary" href={installerUrl}>
        <span>Download setup</span>
      </a>
      <a class="machine-page__control machine-page__control--secondary" href={portableUrl}>
        <span>Portable zip</span>
      </a>
      <a class="machine-page__control machine-page__control--commit" href={checksumsUrl}>
        <span>SHA256SUMS</span>
      </a>
      <a class="machine-page__control machine-page__control--reset" href={sourceUrl} target="_blank" rel="noreferrer">
        <span>Source</span>
      </a>
    </nav>
  </section>
</BaseLayout>
