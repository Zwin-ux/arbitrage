---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { landingVariantOrder, landingVariants } from "../../data/landingVariants.js";
---

<BaseLayout
  title="Superior Lab | Landing Variants"
  description="Compare landing-page variants for Superior and keep homepage changes deliberate."
>
  <section class="content-card">
    <p class="eyebrow">Variant lab</p>
    <h1>Compare the homepage without editing the public route blind.</h1>
    <p>
      This lab keeps a stable control and a stable challenger so copy, composition, and CTA changes can be judged
      deliberately. Use it before replacing the public homepage.
    </p>
  </section>

  <section class="card-grid">
    {landingVariantOrder.map((key) => {
      const variant = landingVariants[key];
      return (
        <article class="content-card">
          <p class="eyebrow">{variant.navLabel}</p>
          <h2>{variant.headlineLead} <span>{variant.headlineAccent}</span></h2>
          <p>{variant.subhead}</p>
          <div class="link-row">
            <a class="button-primary" href={`/lab/${variant.key}`}>
              Open variant
            </a>
            <a class="button-secondary" href={variant.windowsInstallerUrl}>
              Test download
            </a>
          </div>
        </article>
      );
    })}
  </section>

  <section class="content-card">
    <p class="eyebrow">What to judge</p>
    <ul class="criteria-list">
      <li>Does the headline communicate function immediately?</li>
      <li>Does the CTA feel trustworthy enough to click?</li>
      <li>Does the logo feel central without the layout becoming kitsch?</li>
      <li>Does the page feel like a product, not a concept render?</li>
    </ul>
  </section>
</BaseLayout>

<style>
  .content-card {
    padding: 1.8rem;
    border-radius: 1.75rem;
    border: 1px solid rgba(134, 173, 255, 0.14);
    background: linear-gradient(180deg, rgba(10, 16, 34, 0.88), rgba(6, 10, 24, 0.8));
    box-shadow: 0 28px 80px rgba(2, 6, 22, 0.58);
    margin-top: 1.5rem;
  }

  .content-card p {
    color: rgba(221, 233, 255, 0.74);
    line-height: 1.8;
  }

  .button-primary,
  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1.15rem;
    border-radius: 999px;
    font-weight: 600;
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .button-primary {
    background: linear-gradient(135deg, rgba(100, 229, 255, 0.9), rgba(221, 135, 255, 0.9));
    color: #07101f;
    box-shadow: 0 18px 38px rgba(66, 211, 255, 0.18);
  }

  .button-secondary {
    border: 1px solid rgba(134, 173, 255, 0.14);
    background: rgba(255, 255, 255, 0.05);
    color: #eef5ff;
  }

  .card-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .criteria-list {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
    color: rgba(225, 232, 245, 0.78);
    line-height: 1.9;
  }

  .link-row {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .button-primary:hover,
  .button-secondary:hover {
    transform: translateY(-1px);
  }

  @media (min-width: 820px) {
    .card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
