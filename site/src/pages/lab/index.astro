---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { landingVariantOrder, landingVariants } from "../../data/landingVariants.js";
---

<BaseLayout
  title="Superior Lab | Landing Variants"
  description="Compare landing variants for Superior without changing the public route blind."
>
  <section class="machine-page">
    <header class="machine-page__header">
      <div class="machine-page__title">
        <span class="machine-page__label">Lab</span>
        <strong>Landing compare / control vs focus</strong>
      </div>
      <div class="machine-page__status">LOCAL / VARIANTS / DOWNLOAD</div>
    </header>

    <div class="machine-page__body machine-page__body--single">
      <div class="machine-page__column">
        <div class="machine-page__block">
          <span>Use</span>
          <strong>Compare the homepage before swapping the public route.</strong>
          <p>Keep one stable control, one challenger, and one short judging rubric.</p>
        </div>

        <div class="machine-page__rail">
          {landingVariantOrder.map((key) => {
            const variant = landingVariants[key];
            return (
              <article class="machine-page__strip">
                <span class="machine-page__strip-label">{variant.navLabel}</span>
                <div class="machine-page__strip-body">
                  <strong>{variant.heroLine}</strong>
                  <p>{variant.heroSupport}</p>
                  <div class="machine-page__mini-actions">
                    <a class="machine-page__mini-link machine-page__mini-link--primary" href={`/lab/${variant.key}`}>
                      Open
                    </a>
                    <a class="machine-page__mini-link" href={variant.windowsInstallerUrl}>
                      Download
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>

        <div class="machine-page__list">
          <div class="machine-page__row">
            <span>Judge</span>
            <strong>Can you tell what the app does in one screen?</strong>
          </div>
          <div class="machine-page__row">
            <span>Judge</span>
            <strong>Does the download feel safe enough to click?</strong>
          </div>
          <div class="machine-page__row">
            <span>Judge</span>
            <strong>Does the logo lead without drowning the interface?</strong>
          </div>
          <div class="machine-page__row">
            <span>Judge</span>
            <strong>Does it feel like a shipped build instead of a concept mock?</strong>
          </div>
        </div>
      </div>
    </div>

    <nav class="machine-page__controls" aria-label="Lab controls">
      <a class="machine-page__control machine-page__control--primary" href="/lab/control/">
        <span>Open control</span>
      </a>
      <a class="machine-page__control machine-page__control--secondary" href="/lab/focus/">
        <span>Open focus</span>
      </a>
      <a class="machine-page__control machine-page__control--commit" href="/download/">
        <span>Download</span>
      </a>
      <a class="machine-page__control machine-page__control--reset" href="/">
        <span>Home</span>
      </a>
    </nav>
  </section>
</BaseLayout>
