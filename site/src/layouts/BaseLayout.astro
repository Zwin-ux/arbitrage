---
const {
  title = "market-data-recorder",
  description = "Open-source desktop recorder for Polymarket market data with a Windows app, local-first storage, and transparent packaging."
} = Astro.props;

const nav = [
  { href: "/", label: "Home" },
  { href: "/download", label: "Download" },
  { href: "/docs", label: "Docs" },
  { href: "/roadmap", label: "Roadmap" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-mark">S</span>
          <span>
            <strong>Superior</strong>
            <small>Open-source market recorder</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {nav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a class="nav-cta" href="https://github.com/Zwin-ux/arbitrage" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>MIT licensed. Local-first. Built in public.</p>
        <div class="footer-links">
          <a href="https://github.com/Zwin-ux/arbitrage/releases" target="_blank" rel="noreferrer">Releases</a>
          <a href="https://github.com/Zwin-ux/arbitrage" target="_blank" rel="noreferrer">Source</a>
          <a href="/docs">Docs</a>
          <a href="/roadmap">Roadmap</a>
        </div>
      </footer>
    </div>
  </body>
</html>
