---
const {
  title = "Superior",
  description = "Open-source Windows app for practicing event-market timing with replay, local progress, and a locked live path."
} = Astro.props;

const nav = [
  { href: "/", label: "Home" },
  { href: "/download", label: "Download" },
  { href: "/docs", label: "Docs" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0F2E" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/superior-emblem.png" />
    <link rel="icon" type="image/png" href="/assets/superior-app-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <div class="site-frame">
      <header class="site-rail site-rail--top">
        <a class="brand" href="/">
          <span class="brand-mark">
            <img src="/assets/superior-head.png" alt="Superior mark" />
          </span>
          <span>
            <strong>Superior</strong>
            <small>Windows desktop app</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {nav.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a class="nav-cta" href="https://github.com/Zwin-ux/arbitrage" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </nav>
        <p class="site-status">Practice first / local data / live locked</p>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-rail site-rail--bottom">
        <p>Open source / local data / practice first</p>
        <div class="footer-links">
          <a href="https://github.com/Zwin-ux/arbitrage/releases" target="_blank" rel="noreferrer">Releases</a>
          <a href="https://github.com/Zwin-ux/arbitrage" target="_blank" rel="noreferrer">Source</a>
          <a href="/docs">Docs</a>
          <a href="/roadmap">Roadmap</a>
        </div>
      </footer>
    </div>
  </body>
</html>
