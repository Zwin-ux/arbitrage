---
const {
  title = "Superior | Engine Prediction Bot",
  description = "Superior is a Windows bot for Kalshi. Local setup. Automatic after checks."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0F2E" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/superior-wordmark.png" />
    <link rel="icon" type="image/png" href="/assets/superior-app-icon.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
